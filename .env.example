# --- PostgreSQL ---
POSTGRES_DB=patron_erp
POSTGRES_USER=patron
POSTGRES_PASSWORD=cambiar_esta_contraseña

# --- Spring Boot API ---
SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/patron_erp
SPRING_DATASOURCE_USERNAME=patron
SPRING_DATASOURCE_PASSWORD=cambiar_esta_contraseña

# --- JWT ---
JWT_SECRET=cambiar_esta_clave_secreta_por_una_muy_larga_de_256_bits

# --- CORS ---
CORS_ALLOWED_ORIGINS=https://patron.hn,http://localhost:3002,http://localhost:3001
